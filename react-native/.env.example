# ============================================================
# spots-app — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── App Branding ──────────────────────────────────────────
EXPO_PUBLIC_APP_NAME=Spots
EXPO_PUBLIC_APP_SCHEME=spots

# ── Backend API (optional — demo works without) ───────────
EXPO_PUBLIC_API_URL=
EXPO_PUBLIC_API_TOKEN=

# ── Maps ─────────────────────────────────────────────────
# MapTiler API key (optional — OSM tiles used if not set)
EXPO_PUBLIC_MAPTILER_KEY=

# ── Alphinium AI (optional) ───────────────────────────────
# For AI-powered natural language spot search
EXPO_PUBLIC_ALPHINIUM_APP_ID=
EXPO_PUBLIC_ALPHINIUM_AI_KEY=
EXPO_PUBLIC_ALPHINIUM_AI_ENDPOINT=
