{
  "name": "@alphinium/stripe-billing",
  "version": "0.1.0-alpha",
  "description": "Shared Stripe billing package for recurring subscriptions and one-time payments",
  "main": "src/index.js",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:server": "node test-server.js",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.js\"",
    "setup:stripe:test": "node scripts/setup-stripe-products.js --mode=test",
    "setup:stripe:live": "node scripts/setup-stripe-products.js --mode=live",
    "update:config:test": "node scripts/update-config-files.js --mode=test",
    "update:config:live": "node scripts/update-config-files.js --mode=live"
  },
  "keywords": [
    "stripe",
    "billing",
    "subscriptions",
    "payments",
    "alphinium",
    "chatinstance"
  ],
  "author": "Dan Woods <dan@redsitesoftware.com>",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/redsitesoftware/alphinium-stripe-billing.git"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "pg": "^8.13.0",
    "stripe": "^14.15.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
