# ============================================================
# alphinium-app backend — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# --- App ---
# Your product name (shown in the billing UI)
PRODUCT_NAME=My App

# Frontend URL (used for Stripe redirect URLs after checkout)
FRONTEND_URL=http://localhost:8081

# Strapi config
HOST=0.0.0.0
PORT=1337
APP_KEYS=your-app-keys-here
API_TOKEN_SALT=your-api-token-salt
ADMIN_JWT_SECRET=your-admin-jwt-secret
JWT_SECRET=your-jwt-secret

# --- Stripe ---
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Get this from Stripe Dashboard > Webhooks > your endpoint > Signing secret
# For local dev: run `stripe listen --forward-to localhost:1337/api/payment/webhook`
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Stripe Price IDs ---
# Create products in https://dashboard.stripe.com/products
# Then paste the price IDs here.
# OR run: node scripts/create-stripe-products.js
#
# Customise tier names to match your config/plans.js tiers.
# Remove tiers you don't use, add new ones for custom pricing.
STRIPE_PRICE_DEVELOPER_MONTHLY=price_...
STRIPE_PRICE_DEVELOPER_ANNUAL=price_...
STRIPE_PRICE_DEVELOPER_BETA=price_...

STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_TEAM_ANNUAL=price_...
STRIPE_PRICE_TEAM_BETA=price_...

# --- Database ---
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db
